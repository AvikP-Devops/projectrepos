pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('aws-s3-backup-creds')
        AWS_SECRET_ACCESS_KEY = credentials('aws-s3-backup-creds')
        S3_BUCKET             = 's3://technova-jenkins-backup-avik'
    }

    stages {
        stage('Archive') {
            steps {
                sh '''
                set -e
                tar --exclude='.git' -czf backup-$(date +%F-%H-%M).tar.gz .
                '''
            }
        }

        stage('Upload') {
            steps {
                sh '''
                set -e
                aws s3 cp *.tar.gz ${S3_BUCKET}/backups2/
                aws s3 ls ${S3_BUCKET}/backups2/
                '''
            }
        }
    }

    post {
        always {
            sh 'rm -f *.tar.gz'
        }
    }
}
